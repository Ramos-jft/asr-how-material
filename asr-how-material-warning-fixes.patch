+import { prisma } from "@/lib/prisma";
+
+async function getDashboardMetrics() {
+  try {
+    const [
+      products,
+      customers,
+      pendingOrders,
+      reservedStockItems,
+      lowStockProducts,
+    ] = await Promise.all([
+      prisma.product.count(),
+      prisma.customer.count(),
+      prisma.order.count({
+        where: {
+          status: {
+            in: ["AWAITING_PAYMENT", "PENDING_COMPLEMENT"],
+          },
+        },
+      }),
+      prisma.stockMovement.count({
+        where: {
+          type: "RESERVE",
+        },
+      }),
+      prisma.product.count({
+        where: {
+          stockCurrent: {
+            lte: prisma.product.fields.stockMin,
+          },
+        },
+      }),
+    ]);
+
+    return {
+      products,
+      customers,
+      pendingOrders,
+      reservedStockItems,
+      lowStockProducts,
+      hasConnection: true,
+    };
+  } catch {
+    return {
+      products: 0,
+      customers: 0,
+      pendingOrders: 0,
+      reservedStockItems: 0,
+      lowStockProducts: 0,
+      hasConnection: false,
